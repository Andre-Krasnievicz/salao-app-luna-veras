# ─── DATABASE ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/luna

# ─── APP ────────────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# Comma-separated allowed origins (no wildcard in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── SECRETS (generate strong random strings for production) ────
JWT_SECRET=change_me_to_a_random_64char_string_in_production
SESSION_SECRET=change_me_to_another_random_64char_string
CRON_SECRET=change_me_cron_secret

# ─── MERCADO PAGO ────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxx
MERCADOPAGO_PUBLIC_KEY=TEST-xxxx
MERCADOPAGO_WEBHOOK_SECRET=

# ─── WHATSAPP BUSINESS CLOUD API ────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ADMIN_PHONE=5511999999999
WHATSAPP_TEMPLATE_CLIENT_REMINDER=lembrete_cliente
WHATSAPP_TEMPLATE_ADMIN_REMINDER=lembrete_admin

# ─── EMAIL ──────────────────────────────────────────────────────
# Options: noop (just logs), smtp, resend
EMAIL_PROVIDER=noop
EMAIL_FROM=noreply@seudominio.com
# SMTP settings (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Resend settings (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# ─── FRONTEND ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxxx
